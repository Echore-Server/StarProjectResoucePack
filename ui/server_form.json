{
	"long_form@common_dialogs.main_panel_no_buttons": {
		"size": [
			335,
			275
		]
	},
	"custom_form@common_dialogs.main_panel_no_buttons": {
		"size": [
			335,
			275
		]
	},
	"long_form_dynamic_buttons_panel": {
		"type": "stack_panel",
		"size": [
			"100% - 4px",
			"100%c"
		],
		"offset": [
			2,
			0
		],
		"orientation": "vertical",
		"anchor_from": "top_middle",
		"anchor_to": "top_middle",
		"factory": {
			"name": "buttons",
			"control_ids": {
				"button": "server_form.dynamic_button",
				"label": "@server_form.dynamic_label_with_tooltip",
				"header": "@server_form.dynamic_header",
				"divider": "@settings_common.option_group_section_divider"
			}
		}
	},
	"dynamic_label_with_tooltip@settings_common.option_group_spaced_label": {
		"size": [
			"100%",
			"100%c - 16px"
		],
		"offset": [
			0,
			0
		],
		"property_bag": {
			"#string": "",
			"#separator": "\u200b",
			"#search": 0,
			"#value0": "",
			"#value1": ""
		},
		"bindings": [
			{
				"binding_name": "#form_button_text",
				"binding_type": "collection",
				"binding_collection_name": "form_buttons"
			},
			{
				"binding_type": "view",
				"source_property_name": "#form_button_text",
				"target_property_name": "#string"
			},
			{
				"binding_condition": "always",
				"binding_type": "view",
				"source_property_name": "(#search + 1 * ( not (('%.'+#search+'s') * #string = #string) and (('%.'+#search+'s') * #string = ('%.'+#search+'s') * #string - #separator) ))",
				"target_property_name": "#search"
			},
			{
				"binding_type": "view",
				"source_property_name": "((('%.'+#search+'s') * #string) - #separator)",
				"target_property_name": "#value0"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#string - (('%.'+#search+'s') * #string))",
				"target_property_name": "#value1"
			}
		],
		"$text": "#text",
		"$text_bindings": [
			{
				"binding_type": "view",
				"source_control_name": "dynamic_label_with_tooltip",
				"source_property_name": "#value1",
				"target_property_name": "#text"
			}
		],
		"$tooltip_text": "#tooltip_text",
		"$tooltip_bindings": [
			{
				"binding_type": "view",
				"source_control_name": "dynamic_label_with_tooltip",
				"source_property_name": "#value0",
				"target_property_name": "#tooltip_text"
			}
		],
		"controls": [
			{
				"text@settings_common.option_group_label": {}
			},
			{
				"tooltip_trigger@server_form.label_tooltip_trigger": {
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"size": [
						"100%",
						14
					]
				}
			}
		]
	},
	"label_tooltip_popup": {
		"type": "image",
		"texture": "textures/ui/tooltip_default_background",
		"layer": 200,
		"anchor_from": "bottom_left",
		"anchor_to": "top_left",
		"offset": [
			0,
			2
		],
		"size": [
			"100%cm + 10px",
			"100%cm + 10px"
		],
		"controls": [
			{
				"tooltip_text": {
					"type": "label",
					"text": "$tooltip_text",
					"size": [
						"default",
						"default"
					],
					"max_size": [
						295, // yes, hardcoded 
						"default"
					],
					"color": "$item_hover_text_color",
					"bindings": "$tooltip_bindings",
					"alpha": 1.0
				}
			}
		]
	},
	"label_tooltip_trigger@common.button": {
		"size": [
			"100%",
			"100%"
		],
		"layer": 10,
		"sound_volume": 0.0,
		"$pressed_button_name": "button.do_nothing",
		"consume_hover_events": false,
		"focus_enabled": false,
		"controls": [
			{
				"default@common.empty_panel": {}
			},
			{
				"pressed@common.empty_panel": {}
			},
			{
				"hover@server_form.label_tooltip_popup": {}
			}
		]
	}
}
