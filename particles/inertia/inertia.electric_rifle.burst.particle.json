{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "starpve:inertia.electric_rifle.burst",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true
			},
