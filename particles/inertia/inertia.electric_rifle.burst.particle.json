					"v.dy + math.random(-0.25, 0.25)",
					"v.dz + math.random(-0.25, 0.25)"
				]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(0.6, 1.2)"
			},
			"minecraft:particle_initial_speed": "(2 + (v.particle_random_3 * 10)) * 6",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [
