				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 128,
					"texture_height": 128,
					"flipbook": {
						"base_UV": [
							"8 * 7",
							"8 * 9"
						],
						"size_UV": [
							8,
							8
						],
						"step_UV": [
