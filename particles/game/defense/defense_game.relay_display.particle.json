{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "starpve:defense_game.relay_display",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/cube"
			}
		},
		"events": {
			"reset": {
				"expression": "v.count = 0;"
			},
			"increment": {
				"expression": "v.count = v.count + 1;"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": false
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 40,
				"max_particles": 600
			},
			"minecraft:emitter_lifetime_expression": {
				"activation_expression": 1,
				"expiration_expression": "(v.count * 0.4) >= v.length"
			},
			"minecraft:emitter_lifetime_events": {
				"creation_event": "reset"
			},
			"minecraft:emitter_shape_point": {
				"offset": [
					"v.dx * (v.count * 0.4)",
					"v.dy * (v.count * 0.4)",
					"v.dz * (v.count * 0.4)"
				]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1.4
			},
			"minecraft:particle_lifetime_events": {
				"creation_event": "increment",
				"expiration_event": "emission"
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": [
					0.2,
					"0.2 * Math.sqrt(v.dx*v.dx + v.dy*v.dy + v.dz*v.dz)"
				],
				"facing_camera_mode": "direction_y",
				"direction": {
					"mode": "custom",
					"custom_direction": [
						"v.dx",
						"v.dy",
						"v.dz"
					]
				},
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [
						0,
						0
					],
					"uv_size": [
						16,
						16
					]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFF2E2E",
						"1.0": "#00F25959"
					}
				}
			}
		}
	}
}
