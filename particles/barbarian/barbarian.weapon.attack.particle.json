{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "starpve:barbarian.weapon.attack",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/particles"
			}
		},
		"events": {
			"increment": {
				"expression": "v.count = v.count + 5;"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.count = 0;"
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": "72 * 5",
				"max_particles": 1000
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": "1 * 3 / 5"
			},
			"minecraft:emitter_shape_point": {
				"offset": [
					"math.sin(v.count) * 1.75",
					"math.random(-0.1, 0.1)",
					"math.cos(v.count) * 1.75"
				],
				"direction": [
					"math.sin(v.count + 90)",
					0,
					"math.cos(v.count + 90)"
				]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(0.4, 0.8)"
			},
			"minecraft:particle_lifetime_events": {
				"creation_event": "increment"
			},
			"minecraft:particle_initial_spin": {
				"rotation_rate": "math.random(-720, 720) * 2"
			},
			"minecraft:particle_initial_speed": "6 + v.particle_random_1 * 6",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [
					0,
					-5,
					0
				],
				"linear_drag_coefficient": 2
			},
			"minecraft:particle_appearance_billboard": {
				"size": [
					"0.05 + v.particle_random_1 * 0.05",
					"0.05 + v.particle_random_1 * 0.05"
				],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 128,
					"texture_height": 128,
					"flipbook": {
						"base_UV": [
							"8 * 7",
							"8 * 9"
						],
						"size_UV": [
							8,
							8
						],
						"step_UV": [
							-8,
							0
						],
						"max_frame": 8,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FF8D4E1B",
						"1.0": "#00A86838"
					}
				}
			}
		}
	}
}
