{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "starpve:barbarian_quake_blood",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/spiky_circle"
			}
		},
		"events": {
			"increment": {
				"expression": "v.lock > 60 ? (v.lock = 0;v.count = v.count + 1;) : (v.lock = v.lock + 1;);"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.lock = 0;v.count = 1;v.radius = 20;v.time = 1;"
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": "60 * v.radius / v.time",
				"max_particles": 600
			},
			"minecraft:emitter_lifetime_looping": {
				"active_time": 1,
				"sleep_time": 1
			},
			"minecraft:emitter_shape_disc": {
				"offset": [0, 0.1, 0],
				"radius": "v.count + math.random(-0.25, 0.25)",
				"surface_only": true,
				"direction": [0, 1, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(0.6, 0.9)"
			},
			"minecraft:particle_lifetime_events": {
				"creation_event": "increment"
			},
			"minecraft:particle_initial_speed": "math.random(0.5, 12)",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, -25, 0],
				"linear_drag_coefficient": 6
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["0.075 + v.particle_random_1 * 0.125", "0.075 + v.particle_random_1 * 0.125"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 512,
					"texture_height": 512,
					"uv": [0, 0],
					"uv_size": [512, 512]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_drag": 1,
				"collision_radius": 0.1
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FF710000",
						"1.0": "#000E0101"
					}
				}
			}
		}
	}
}
